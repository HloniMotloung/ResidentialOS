# .env.example
# Copy this to .env and fill in your values.
# Never commit .env to git — it contains secrets.

# Django
SECRET_KEY=your-secret-key-here
DJANGO_SETTINGS_MODULE=config.settings.local

# Database (local uses SQLite so leave blank for dev)
DATABASE_URL=

# Email (leave blank locally — emails print to terminal)
SENDGRID_API_KEY=
DEFAULT_FROM_EMAIL=noreply@tloupropertysolutions.co.za

# CORS (comma-separated list of allowed frontend origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:8000

# Redis (leave blank locally — tasks run eagerly without it)
REDIS_URL=
